# VitaDuo Backend Environment Variables
# Copy this file to .env and fill in the values

# Required
SECRET_KEY=                        # Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=                    # Generate: python -c "import secrets; print(secrets.token_hex(32))"
DATABASE_URL=postgresql://user:pass@host:5432/vitaduo

# Application
FLASK_APP=app.py
FLASK_ENV=production
DEBUG=False
FLASK_DEBUG=false
PORT=9021

# AI Service (ZhipuAI GLM)
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4/chat/completions
GLM_MODEL=glm-4-plus

# CORS
CORS_ORIGINS=https://dd3.tpr.wales,https://vitaduo.tpr.wales
